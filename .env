# replace the dots with actual ids
# Get these from the Discord Developer Portal
BOT_TOKEN=.
CLIENT_ID=.
GUILD_ID=.

# i suggest making a "Staff" role that will have no perms just a decoration roles with access to do these commands
# no need to add multiple role ids just add one and make sure every staff member has that role
STAFF_ROLE_IDS=.

# sends logs into a channel about punishments (mutes, bans, etc.), i suggest hiding the channel from everyone except staff roles
PUNISHMENT_LOG_ID=.

# Set to 'true' to activate, 'false' to disable
AUTO_MOD_ENABLED=true
ANTI_RAID_ENABLED=true
ESCALATION_SYSTEM=true
DM_NOTIFICATIONS=true

# The role given to users when they are muted
DEFAULT_MUTE_ROLE_ID=.
# channel to show staff what commands they can do
STAFF_GUIDE_CHANNEL_ID=.